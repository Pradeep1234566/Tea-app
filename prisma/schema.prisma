datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}
model Room {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  roomId    String
  createdAt DateTime @default(now())  
  room      Room     @relation(fields: [roomId], references: [id])
}

model Vote {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  target    String
  createdAt DateTime @default(now())
}


