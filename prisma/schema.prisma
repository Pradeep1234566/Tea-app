// ─────────────────────────────────────────────────────────────────────────────
// FILE: prisma/schema.prisma   (updated — added createdAt fields)
// ─────────────────────────────────────────────────────────────────────────────

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

model Room {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  roomId    String
  createdAt DateTime @default(now())   // ← added: needed for ordered player list
  room      Room     @relation(fields: [roomId], references: [id])
}

model Vote {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  target    String
  createdAt DateTime @default(now())
}


